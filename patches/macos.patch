+
+static int borgTkHelpersLoaded = 0;
+
+static void
+BorgEnsureTkHelpers(Tcl_Interp *interp)
+{
+    if (!borgTkHelpersLoaded) {
+	BorgEvalIgnore(interp, borgTkHelpers);
+	borgTkHelpersLoaded = 1;
+    }
+}
+
+/*
+ *----------------------------------------------------------------------
+ * Speech via the macOS "say" command.  We track the last spoken pid so
+ * stopspeak / isspeaking / endspeak work.
+ *----------------------------------------------------------------------
+ */
+
+static pid_t borgSayPid = 0;
+
+static int
+BorgSpeak(Tcl_Interp *interp, const char *text, const char *rate)
+{
+    const char *argv[6];
+    int n = 0;
+    char ratebuf[32];
+
+    /* Stop any current utterance first (Android replaces by default). */
+    if (borgSayPid > 0 && kill(borgSayPid, 0) == 0) {
+	kill(borgSayPid, SIGTERM);
+    }
+    argv[n++] = "say";
+    if (rate != NULL && rate[0] != '\0') {
+	/*
+	 * Android speak rate is a multiplier around 1.0; "say" wants words
+	 * per minute (default ~175).  Map multiplier -> wpm when it looks
+	 * like a small float, else pass through as wpm.
+	 */
+	double r = atof(rate);
+	int wpm;
+	if (r > 0.0 && r <= 4.0) {
+	    wpm = (int)(r * 175.0);
+	} else {
+	    wpm = (int) r;
+	}
+	if (wpm >= 40 && wpm <= 600) {
+	    snprintf(ratebuf, sizeof(ratebuf), "%d", wpm);
+	    argv[n++] = "-r";
+	    argv[n++] = ratebuf;
+	}
+    }
+    argv[n++] = text;
+    argv[n] = NULL;
+    borgSayPid = BorgSpawn(argv);
+    return TCL_OK;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * Notification via osascript "display notification".
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgNotify(Tcl_Interp *interp, const char *title, const char *text)
+{
+    Tcl_DString script;
+    const char *argv[5];
+    const char *p;
+
+    /* Build: display notification "TEXT" with title "TITLE" */
+    Tcl_DStringInit(&script);
+    Tcl_DStringAppend(&script, "display notification \"", -1);
+    for (p = (text ? text : ""); *p; p++) {
+	if (*p == '"' || *p == '\\') {
+	    Tcl_DStringAppend(&script, "\\", 1);
+	}
+	Tcl_DStringAppend(&script, p, 1);
+    }
+    Tcl_DStringAppend(&script, "\" with title \"", -1);
+    for (p = (title ? title : "AndroWish"); *p; p++) {
+	if (*p == '"' || *p == '\\') {
+	    Tcl_DStringAppend(&script, "\\", 1);
+	}
+	Tcl_DStringAppend(&script, p, 1);
+    }
+    Tcl_DStringAppend(&script, "\"", -1);
+
+    argv[0] = "osascript";
+    argv[1] = "-e";
+    argv[2] = Tcl_DStringValue(&script);
+    argv[3] = NULL;
+    (void) BorgSpawn(argv);
+    Tcl_DStringFree(&script);
+    return TCL_OK;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * Screen brightness via the private DisplayServices framework (dlopen'd),
+ * which is the only reliable absolute brightness API on Apple Silicon.
+ *----------------------------------------------------------------------
+ */
+
+typedef int (*DSGetBrightnessFn)(CGDirectDisplayID, float *);
+typedef int (*DSSetBrightnessFn)(CGDirectDisplayID, float);
+
+static int
+BorgBrightnessFns(DSGetBrightnessFn *getp, DSSetBrightnessFn *setp)
+{
+    static int tried = 0;
+    static DSGetBrightnessFn getfn = NULL;
+    static DSSetBrightnessFn setfn = NULL;
+
+    if (!tried) {
+	void *h = dlopen("/System/Library/PrivateFrameworks/"
+			 "DisplayServices.framework/DisplayServices", RTLD_LAZY);
+	if (h != NULL) {
+	    getfn = (DSGetBrightnessFn) dlsym(h, "DisplayServicesGetBrightness");
+	    setfn = (DSSetBrightnessFn) dlsym(h, "DisplayServicesSetBrightness");
+	}
+	tried = 1;
+    }
+    if (getp) *getp = getfn;
+    if (setp) *setp = setfn;
+    return (getfn != NULL && setfn != NULL);
+}
+
+/*
+ *----------------------------------------------------------------------
+ * sysctl string helper.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgSysctlStr(const char *name, char *buf, size_t buflen)
+{
+    size_t len = buflen;
+
+    buf[0] = '\0';
+    if (sysctlbyname(name, buf, &len, NULL, 0) == 0) {
+	if (len < buflen) {
+	    buf[len] = '\0';
+	}
+	return 1;
+    }
+    return 0;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * sharedpreferences: a typed key/value store backed by one Tcl-dict file
+ * per "file" name under ~/Library/Application Support/undroidwish/prefs/.
+ * Each value is stored as a 2-element list {type value}.
+ *----------------------------------------------------------------------
+ */
+
+static void
+BorgPrefsPath(const char *file, char *out, size_t outlen)
+{
+    const char *home = getenv("HOME");
+
+    if (home == NULL) home = "/tmp";
+    snprintf(out, outlen,
+	     "%s/Library/Application Support/undroidwish/prefs/%s.tcldict",
+	     home, file);
+}
+
+static void
+BorgPrefsMkdir(const char *home)
+{
+    char p[2048];
+
+    snprintf(p, sizeof(p), "%s/Library/Application Support", home);
+    mkdir(p, 0755);
+    snprintf(p, sizeof(p), "%s/Library/Application Support/undroidwish", home);
+    mkdir(p, 0755);
+    snprintf(p, sizeof(p),
+	     "%s/Library/Application Support/undroidwish/prefs", home);
+    mkdir(p, 0755);
+}
+
+/*
+ * Returns a dict Tcl_Obj with refCount 0; the caller takes ownership
+ * (Tcl_IncrRefCount before mutating, Tcl_DecrRefCount when done).  A missing
+ * or malformed file yields a fresh empty dict.
+ */
+static Tcl_Obj *
+BorgPrefsLoad(const char *file)
+{
+    char path[2048];
+    Tcl_Obj *dict = NULL;
+    Tcl_Channel chan;
+
+    BorgPrefsPath(file, path, sizeof(path));
+    chan = Tcl_OpenFileChannel(NULL, path, "r", 0);
+    if (chan != NULL) {
+	Tcl_Obj *data = Tcl_NewObj();
+	Tcl_IncrRefCount(data);
+	Tcl_SetChannelOption(NULL, chan, "-translation", "binary");
+	if (Tcl_ReadChars(chan, data, -1, 0) >= 0) {
+	    int size;
+	    if (Tcl_DictObjSize(NULL, data, &size) == TCL_OK) {
+		/* Private refCount-0 copy for the caller to own and mutate. */
+		dict = Tcl_DuplicateObj(data);
+	    }
+	}
+	Tcl_DecrRefCount(data);
+	Tcl_Close(NULL, chan);
+    }
+    if (dict == NULL) {
+	dict = Tcl_NewDictObj();
+    }
+    return dict;
+}
+
+static int
+BorgPrefsSave(const char *file, Tcl_Obj *dict)
+{
+    char path[2048];
+    const char *home = getenv("HOME");
+    Tcl_Channel chan;
+    const char *str;
+    int len, ok = 0;
+
+    if (home == NULL) home = "/tmp";
+    BorgPrefsMkdir(home);
+    BorgPrefsPath(file, path, sizeof(path));
+    chan = Tcl_OpenFileChannel(NULL, path, "w", 0644);
+    if (chan != NULL) {
+	Tcl_SetChannelOption(NULL, chan, "-translation", "binary");
+	str = Tcl_GetStringFromObj(dict, &len);
+	if (Tcl_WriteChars(chan, str, len) >= 0) {
+	    ok = 1;
+	}
+	Tcl_Close(NULL, chan);
+    }
+    return ok;
+}
+
+/*
+ * Subcommand handlers for sharedpreferences.  Returns a Tcl status.
+ *   borg sharedpreferences FILE OP ?KEY VALUE?
+ */
+static int
+BorgSharedPrefs(Tcl_Interp *interp, int objc, Tcl_Obj *const objv[])
+{
+    static const char *const shpCmds[] = {
+	"getboolean", "getfloat", "getint", "getlong", "getstring",
+	"setboolean", "setfloat", "setint", "setlong", "setstring",
+	"remove", "clear", "all", "alltypes", "keys", NULL
+    };
+    enum shpCmd {
+	SHP_getbool, SHP_getfloat, SHP_getint, SHP_getlong, SHP_getstring,
+	SHP_setbool, SHP_setfloat, SHP_setint, SHP_setlong, SHP_setstring,
+	SHP_remove, SHP_clear, SHP_all, SHP_alltypes, SHP_keys
+    };
+    int cmd;
+    const char *file;
+    Tcl_Obj *dict, *key = NULL, *stored = NULL;
+
+    if ((objc < 4) || (objc > 6)) {
+	Tcl_WrongNumArgs(interp, 2, objv, "file op ?key value?");
+	return TCL_ERROR;
+    }
+    if (Tcl_GetIndexFromObj(interp, objv[3], shpCmds, "option", 0,
+			    &cmd) != TCL_OK) {
+	return TCL_ERROR;
+    }
+    file = Tcl_GetString(objv[2]);
+    if (objc > 4) {
+	key = objv[4];
+    }
+    dict = BorgPrefsLoad(file);
+    Tcl_IncrRefCount(dict);
+
+    if (key != NULL) {
+	Tcl_DictObjGet(NULL, dict, key, &stored);
+    }
+
+    switch ((enum shpCmd) cmd) {
+    case SHP_getbool: case SHP_getfloat: case SHP_getint:
+    case SHP_getlong: case SHP_getstring: {
+	/* objv[5] is the default if missing. */
+	Tcl_Obj *val = NULL;
+	if (objc != 6) {
+	    Tcl_DecrRefCount(dict);
+	    Tcl_WrongNumArgs(interp, 2, objv, "file getX key default");
+	    return TCL_ERROR;
+	}
+	if (stored != NULL) {
+	    /* stored = {type value}; take value (last element). */
+	    int n;
+	    Tcl_Obj **el;
+	    if (Tcl_ListObjGetElements(NULL, stored, &n, &el) == TCL_OK &&
+		n == 2) {
+		val = el[1];
+	    } else {
+		val = stored;
+	    }
+	}
+	if (val == NULL) {
+	    val = objv[5];
+	}
+	Tcl_SetObjResult(interp, val);
+	break;
+    }
+    case SHP_setbool: case SHP_setfloat: case SHP_setint:
+    case SHP_setlong: case SHP_setstring: {
+	const char *type;
+	Tcl_Obj *pair;
+	if (objc != 6) {
+	    Tcl_DecrRefCount(dict);
+	    Tcl_WrongNumArgs(interp, 2, objv, "file setX key value");
+	    return TCL_ERROR;
+	}
+	switch ((enum shpCmd) cmd) {
+	case SHP_setbool:   type = "boolean"; break;
+	case SHP_setfloat:  type = "float";   break;
+	case SHP_setint:    type = "int";     break;
+	case SHP_setlong:   type = "long";    break;
+	default:            type = "string";  break;
+	}
+	pair = Tcl_NewListObj(0, NULL);
+	Tcl_ListObjAppendElement(NULL, pair, Tcl_NewStringObj(type, -1));
+	Tcl_ListObjAppendElement(NULL, pair, objv[5]);
+	Tcl_DictObjPut(NULL, dict, key, pair);
+	BorgPrefsSave(file, dict);
+	Tcl_SetObjResult(interp, objv[5]);
+	break;
+    }
+    case SHP_remove:
+	if (key != NULL) {
+	    Tcl_DictObjRemove(NULL, dict, key);
+	    BorgPrefsSave(file, dict);
+	}
+	break;
+    case SHP_clear: {
+	Tcl_Obj *empty = Tcl_NewDictObj();
+	BorgPrefsSave(file, empty);
+	Tcl_DecrRefCount(empty);
+	break;
+    }
+    case SHP_keys: {
+	Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+	Tcl_DictSearch s;
+	Tcl_Obj *k, *v;
+	int done;
+	if (Tcl_DictObjFirst(NULL, dict, &s, &k, &v, &done) == TCL_OK) {
+	    for (; !done; Tcl_DictObjNext(&s, &k, &v, &done)) {
+		Tcl_ListObjAppendElement(NULL, list, k);
+	    }
+	    Tcl_DictObjDone(&s);
+	}
+	Tcl_SetObjResult(interp, list);
+	break;
+    }
+    case SHP_all: case SHP_alltypes: {
+	Tcl_Obj *out = Tcl_NewListObj(0, NULL);
+	Tcl_DictSearch s;
+	Tcl_Obj *k, *v;
+	int done;
+	if (Tcl_DictObjFirst(NULL, dict, &s, &k, &v, &done) == TCL_OK) {
+	    for (; !done; Tcl_DictObjNext(&s, &k, &v, &done)) {
+		int n;
+		Tcl_Obj **el;
+		Tcl_ListObjAppendElement(NULL, out, k);
+		if (cmd == SHP_alltypes) {
+		    /* {type value} */
+		    Tcl_ListObjAppendElement(NULL, out, v);
+		} else if (Tcl_ListObjGetElements(NULL, v, &n, &el) == TCL_OK
+			   && n == 2) {
+		    Tcl_ListObjAppendElement(NULL, out, el[1]);
+		} else {
+		    Tcl_ListObjAppendElement(NULL, out, v);
+		}
+	    }
+	    Tcl_DictObjDone(&s);
+	}
+	Tcl_SetObjResult(interp, out);
+	break;
+    }
+    }
+    Tcl_DecrRefCount(dict);
+    return TCL_OK;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * displaymetrics via CoreGraphics.
+ *----------------------------------------------------------------------
+ */
+
+static int
+BorgDisplayMetrics(Tcl_Interp *interp)
+{
+    CGDirectDisplayID d = CGMainDisplayID();
+    size_t wpx = CGDisplayPixelsWide(d);
+    size_t hpx = CGDisplayPixelsHigh(d);
+    CGSize mm = CGDisplayScreenSize(d);	/* millimetres */
+    double xdpi = 96.0, ydpi = 96.0, density, sdensity;
+    int ddpi;
+    char buf[256];
+
+    if (mm.width > 0.0) {
+	xdpi = (double) wpx / (mm.width / 25.4);
+    }
+    if (mm.height > 0.0) {
+	ydpi = (double) hpx / (mm.height / 25.4);
+    }
+    /* Android density baseline is 160dpi. */
+    density = ((xdpi + ydpi) / 2.0) / 160.0;
+    ddpi = (int)(density * 160.0 + 0.5);
+    sdensity = density;
+    snprintf(buf, sizeof(buf),
+	     "density %.3g densitydpi %d width %lu height %lu "
+	     "xdpi %.4g ydpi %.4g scaleddensity %.3g rotation 0",
+	     density, ddpi, (unsigned long) wpx, (unsigned long) hpx,
+	     xdpi, ydpi, sdensity);
+    Tcl_SetObjResult(interp, Tcl_NewStringObj(buf, -1));
+    return TCL_OK;
+}
+
+/*
+ *----------------------------------------------------------------------
+ * osbuildinfo: flat {key value ...} list shaped like Android's, filled
+ * from sysctl / environment.
+ *----------------------------------------------------------------------
+ */
+
+static void
+BorgAddKV(Tcl_Obj *list, const char *k, const char *v)
+{
+    Tcl_ListObjAppendElement(NULL, list, Tcl_NewStringObj(k, -1));
+    Tcl_ListObjAppendElement(NULL, list, Tcl_NewStringObj(v ? v : "", -1));
+}
+
+/*
+ * Friendly Apple product name (e.g. "MacBook Air"), cached.  macOS no longer
+ * encodes the product line in hw.model ("Mac16,12"), so we read the marketing
+ * name from system_profiler once.  Falls back to "Mac".
+ */
+static const char *
+BorgMacProduct(void)
+{
+    static char prod[128] = "";
+    static int done = 0;
+
+    if (!done) {
+	FILE *fp;
+
+	done = 1;
+	fp = popen("/usr/sbin/system_profiler SPHardwareDataType 2>/dev/null"
+		   " | /usr/bin/awk -F': ' '/Model Name/{print $2; exit}'", "r");
+	if (fp != NULL) {
+	    if (fgets(prod, sizeof(prod), fp) != NULL) {
+		size_t n = strlen(prod);
+		while (n > 0 && (prod[n-1] == '\n' || prod[n-1] == '\r' ||
+				 prod[n-1] == ' ')) {
+		    prod[--n] = '\0';
+		}
+	    }
+	    pclose(fp);
+	}
+	if (prod[0] == '\0') {
+	    strlcpy(prod, "Mac", sizeof(prod));
+	}
+    }
+    return prod;
+}
+
+static int
+BorgOSBuildInfo(Tcl_Interp *interp)
+{
+    Tcl_Obj *list = Tcl_NewListObj(0, NULL);
+    char osver[128], darwin[128], model[128], machine[64], cpu[256], host[256];
+    char target[128], fp[1024];
+
+    BorgSysctlStr("kern.osproductversion", osver, sizeof(osver));
+    BorgSysctlStr("kern.osversion", darwin, sizeof(darwin));
+    BorgSysctlStr("hw.model", model, sizeof(model));
+    BorgSysctlStr("hw.machine", machine, sizeof(machine));
+    BorgSysctlStr("machdep.cpu.brand_string", cpu, sizeof(cpu));
+    if (!BorgSysctlStr("hw.target", target, sizeof(target))) {
+	target[0] = '\0';
+    }
+    if (gethostname(host, sizeof(host)) != 0) host[0] = '\0';
+
+    /*
+     * Fill the standard (Android-shaped) osbuildinfo keys with real Apple
+     * values so callers identify the platform from the EXISTING keys -- no
+     * non-standard "borg platform"/"os" key needed:
+     *   manufacturer "Apple"  -> Apple (vs the device maker on Android)
+     *   model        hw.model -> "Mac..."  (iWish reports "iPad.."/"iPhone.." on iOS)
+     *   product      "undroidwish"          (the iWish build reports "iWish")
+     * Android-style fingerprint: brand/product/device:release/id/incr:type/tags
+     */
+    snprintf(fp, sizeof(fp), "Apple/Mac/%s:%s/%s/0:user/release-keys",
+	     model, osver, darwin);
+
+    BorgAddKV(list, "version.codename", "REL");
+    BorgAddKV(list, "version.incremental", darwin);
+    BorgAddKV(list, "version.release", osver);
+    BorgAddKV(list, "version.sdk", "0");	/* Android API level; no Apple equiv */
+    BorgAddKV(list, "board", target[0] ? target : model);
+    BorgAddKV(list, "bootloader", "");
+    BorgAddKV(list, "brand", "Apple");
+    BorgAddKV(list, "cpu_abi", machine);
+    BorgAddKV(list, "cpu_abi2", "");
+    BorgAddKV(list, "device", model);
+    BorgAddKV(list, "display", darwin);
+    BorgAddKV(list, "fingerprint", fp);
+    BorgAddKV(list, "hardware", cpu);
+    BorgAddKV(list, "host", host);
+    BorgAddKV(list, "id", darwin);
+    BorgAddKV(list, "manufacturer", "Apple");
+    BorgAddKV(list, "model", model);
+    BorgAddKV(list, "product", BorgMacProduct());
+    BorgAddKV(list, "serial", "unknown");
+    BorgAddKV(list, "tags", "release-keys");
+    BorgAddKV(list, "time", "0");
+    BorgAddKV(list, "type", "user");
+    BorgAddKV(list, "user", getenv("USER") ? getenv("USER") : "");
+    BorgAddKV(list, "radio", "");
+    Tcl_SetObjResult(interp, list);
+    return TCL_OK;
+}
