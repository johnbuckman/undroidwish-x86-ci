+    }
+
     if (SdlTkX.draw_later & SDLTKX_RENDCLR2) {
 	SdlTkX.draw_later &= ~SDLTKX_RENDCLR2;
 	SDL_SetRenderDrawColor(SdlTkX.sdlrend, 0, 0, 0, 255);
@@ -955,6 +1127,7 @@ SdlTkGfxUpdateRegion(SDL_Renderer *rend, SDL_Texture *tex,
 	if (SdlTkX.arg_swcursor > 0) {
 	    DrawSWCursor(rend, tex);
 	}
+	SdlTkGfxDrawBorgToast(rend);
 	SDL_RenderPresent(rend);
     }
 #endif
@@ -979,6 +1152,7 @@ SdlTkGfxPresent(SDL_Renderer *rend, SDL_Texture *tex)
     if (SdlTkX.arg_swcursor > 0) {
 	DrawSWCursor(rend, tex);
     }
+    SdlTkGfxDrawBorgToast(rend);
 #endif
     SDL_RenderPresent(rend);
 }
