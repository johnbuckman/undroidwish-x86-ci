+/*
+ * tkBorgOSX.c --
+ *
+ *	macOS (desktop) implementation of the "borg" Tcl command for
+ *	undroidwish.  AndroWish's borg command (tkBorg.c) is a JNI bridge to
+ *	the Android framework and is deliberately omitted from undroidwish
+ *	("AndroWish sans the borg").  This file provides a drop-in borg
+ *	command for the macOS desktop build whose subcommand surface matches
+ *	the documented Android command exactly (see
+ *	https://androwish.org/home/wiki?name=Android+facilities).
+ *
+ *	Design goals, in order:
+ *	  1. Every documented subcommand exists and NEVER raises a Tcl error
+ *	     for a well-formed call -- subcommands with no macOS analog are
+ *	     safe no-ops returning an empty string (or the Android-shaped
+ *	     "empty" value), so unmodified AndroWish/de1app code runs.
+ *	  2. Subcommands that DO map onto a native macOS facility get a real
+ *	     best-effort implementation using only system facilities already
+ *	     available to the build (libc, Tcl/Tk, CoreFoundation, IOKit,
+ *	     CoreGraphics) plus standard command-line tools (say, open,
+ *	     osascript) launched via posix_spawn.  No new hard link
+ *	     dependency on a private framework: DisplayServices (for screen
+ *	     brightness) is reached lazily via dlopen.
+ *
+ *	This is intended as a patch submittable to the AndroWish maintainer;
+ *	it is guarded for __APPLE__ and is self-contained.
+ *
+ * Copyright (c) 2026 John Buckman.
+ *
+ * See the file "license.terms" for information on usage and redistribution of
+ * this file, and for a DISCLAIMER OF ALL WARRANTIES.
+ */
+
+#include <tcl.h>
+
+/*
+ * Note: we deliberately do NOT include tkBorg.h here -- on Android it pulls in
+ * <jni.h>.  The Borg_Init prototype is declared locally so this file builds as
+ * a self-contained desktop Tcl extension.
+ */
+#ifndef Borg_Init
+EXTERN int Borg_Init(Tcl_Interp *interp);
+#endif
+
+#ifdef __APPLE__
+
+#include <stddef.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <signal.h>
+#include <spawn.h>
+#include <errno.h>
+#include <dlfcn.h>
+#include <locale.h>
+#include <sys/sysctl.h>
+#include <sys/types.h>
+#include <sys/stat.h>
+#include <ifaddrs.h>
+#include <net/if.h>
+#include <netinet/in.h>
+
+#include <CoreFoundation/CoreFoundation.h>
+#include <CoreGraphics/CoreGraphics.h>
+#include <IOKit/IOKitLib.h>
+#include <IOKit/usb/IOUSBLib.h>
+
+extern char **environ;
+
+/*
+ *----------------------------------------------------------------------
+ * Small process helpers.
+ *----------------------------------------------------------------------
+ */
+
+/*
+ * Launch argv detached (fire-and-forget).  Returns the child pid, or -1 on
+ * failure.  argv must be NULL-terminated.
+ */
+static pid_t
+BorgSpawn(const char *const argv[])
+{
+    pid_t pid = -1;
+    posix_spawn_file_actions_t fa;
+    posix_spawn_file_actions_t *fap = NULL;
+
+    if (posix_spawn_file_actions_init(&fa) == 0) {
+	/* Silence the child's stdout/stderr so it never pollutes ours. */
+	posix_spawn_file_actions_addopen(&fa, STDOUT_FILENO, "/dev/null",
+					 O_WRONLY, 0);
+	posix_spawn_file_actions_addopen(&fa, STDERR_FILENO, "/dev/null",
+					 O_WRONLY, 0);
+	fap = &fa;
+    }
+    if (posix_spawnp(&pid, argv[0], fap, NULL, (char *const *) argv,
+		     environ) != 0) {
+	pid = -1;
+    }
+    if (fap != NULL) {
+	posix_spawn_file_actions_destroy(&fa);
+    }
+    /*
+     * Reap eventually: detach by ignoring; the global SIGCHLD disposition of
+     * the wish process already reaps, but to be safe we double-fork-free by
+     * not tracking.  A short waitpid(WNOHANG) is intentionally omitted so we
+     * do not block.
+     */
+    return pid;
+}
+
+/*
+ * Run a command line and capture its trimmed stdout into a freshly allocated
+ * Tcl_Obj (refcount 0), or NULL on failure.  Uses Tcl's [exec] so quoting and
+ * pipe handling are correct and the interp result is restored afterwards.
+ */
+static Tcl_Obj *
+BorgCapture(Tcl_Interp *interp, int argc, const char *const argv[])
+{
+    Tcl_Obj *cmd, *saved, *result = NULL;
+    int i, code;
+
+    cmd = Tcl_NewListObj(0, NULL);
+    Tcl_ListObjAppendElement(NULL, cmd, Tcl_NewStringObj("exec", -1));
+    for (i = 0; i < argc; i++) {
+	Tcl_ListObjAppendElement(NULL, cmd, Tcl_NewStringObj(argv[i], -1));
+    }
+    Tcl_IncrRefCount(cmd);
+    saved = Tcl_GetObjResult(interp);
+    Tcl_IncrRefCount(saved);
+    code = Tcl_EvalObjEx(interp, cmd, TCL_EVAL_DIRECT);
+    if (code == TCL_OK) {
+	result = Tcl_DuplicateObj(Tcl_GetObjResult(interp));
+    }
+    Tcl_SetObjResult(interp, saved);
+    Tcl_DecrRefCount(saved);
+    Tcl_DecrRefCount(cmd);
+    return result;
+}
+
+/*
+ * Evaluate a snippet of Tcl ignoring errors (best-effort UI helpers etc.).
+ */
+static void
+BorgEvalIgnore(Tcl_Interp *interp, const char *script)
+{
+    Tcl_Obj *saved = Tcl_GetObjResult(interp);
+
+    Tcl_IncrRefCount(saved);
+    (void) Tcl_EvalEx(interp, script, -1, TCL_EVAL_DIRECT);
+    Tcl_SetObjResult(interp, saved);
+    Tcl_DecrRefCount(saved);
+}
